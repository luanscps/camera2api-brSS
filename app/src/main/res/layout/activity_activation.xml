<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f172a"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="28dp"
        android:minHeight="600dp">

        <!-- Ícone / logo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎥"
            android:textSize="56sp"
            android:layout_marginBottom="8dp" />

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Camera2 RTSP"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#38bdf8"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ativação de Licença"
            android:textSize="14sp"
            android:textColor="#94a3b8"
            android:layout_marginBottom="36dp" />

        <!-- Card de ativação -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1e293b"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔑 Digite seu serial de licença"
                android:textSize="13sp"
                android:textColor="#f1f5f9"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Input do serial -->
            <EditText
                android:id="@+id/inputSerial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="XXXX-XXXX-XXXX"
                android:textColorHint="#475569"
                android:textColor="#f1f5f9"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:gravity="center"
                android:inputType="textCapCharacters"
                android:letterSpacing="0.15"
                android:maxLength="14"
                android:background="#263348"
                android:padding="14dp"
                android:layout_marginBottom="16dp" />

            <!-- Botão Ativar -->
            <Button
                android:id="@+id/btnActivate"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="ATIVAR AGORA"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#0f172a"
                android:backgroundTint="#38bdf8"
                android:layout_marginBottom="12dp" />

            <!-- Loading -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="8dp" />

            <!-- Status -->
            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="13sp"
                android:textColor="#10b981"
                android:visibility="gone"
                android:lineSpacingExtra="3dp" />

        </LinearLayout>

        <!-- Device ID (suporte) -->
        <TextView
            android:id="@+id/txtDeviceId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ID: ..."
            android:textSize="11sp"
            android:textColor="#475569"
            android:fontFamily="monospace"
            android:layout_marginBottom="24dp" />

        <!-- Divisor -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1e293b"
            android:layout_marginBottom="20dp" />

        <!-- Botão comprar -->
        <TextView
            android:id="@+id/btnBuy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ainda não tem uma licença? Comprar agora →"
            android:textSize="13sp"
            android:textColor="#38bdf8"
            android:padding="8dp" />

    </LinearLayout>
</ScrollView>
