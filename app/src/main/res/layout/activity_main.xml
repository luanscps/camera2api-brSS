<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f172a">

    <!-- Preview da câmera (ocupa tela toda) -->
    <TextureView
        android:id="@+id/cameraPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Overlay de status no topo -->
    <LinearLayout
        android:id="@+id/topOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#CC0f172a"
        android:padding="16dp"
        android:layout_gravity="top">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📡 Camera2 RTSP Server"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#38bdf8"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏳ Inicializando..."
            android:textSize="13sp"
            android:textColor="#f1f5f9"
            android:fontFamily="monospace"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>

    <!-- HUD de informações em tempo real (canto superior direito) -->
    <include
        android:id="@+id/hudLayout"
        layout="@layout/layout_hud"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="120dp"
        android:layout_marginEnd="16dp" />

    <!-- Indicador RTSP ativo (canto inferior direito) -->
    <TextView
        android:id="@+id/rtspIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏹ RTSP OFFLINE"
        android:textSize="12sp"
        android:textColor="#ef4444"
        android:background="#CC1e293b"
        android:padding="8dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="100dp"
        android:layout_marginEnd="16dp" />

    <!-- Botões flutuantes (FABs) no lado esquerdo -->
    <LinearLayout
        android:id="@+id/fabContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="16dp">

        <!-- FAB: Alternar câmera -->
        <ImageButton
            android:id="@+id/fabSwitchCamera"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_fab"
            android:src="@android:drawable/ic_menu_camera"
            android:tint="#0f172a"
            android:contentDescription="Trocar câmera"
            android:layout_marginBottom="16dp" />

        <!-- FAB: Flash/Lanterna -->
        <ImageButton
            android:id="@+id/fabFlash"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_fab"
            android:src="@android:drawable/ic_menu_gallery"
            android:tint="#0f172a"
            android:contentDescription="Flash"
            android:layout_marginBottom="16dp" />

        <!-- FAB: Tirar foto -->
        <ImageButton
            android:id="@+id/fabTakePhoto"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_fab"
            android:src="@android:drawable/ic_menu_add"
            android:tint="#0f172a"
            android:contentDescription="Tirar foto"
            android:layout_marginBottom="16dp" />

        <!-- FAB: Alternar HUD -->
        <ImageButton
            android:id="@+id/fabToggleHud"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_fab"
            android:src="@android:drawable/ic_menu_info_details"
            android:tint="#0f172a"
            android:contentDescription="Alternar HUD" />

    </LinearLayout>

    <!-- Botão de controles (canto inferior esquerdo) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_menu_preferences"
        app:tint="#0f172a"
        app:backgroundTint="#38bdf8"
        android:contentDescription="Abrir controles" />

    <!-- Bottom Sheet (painel de controles) -->
    <include
        android:id="@+id/bottomSheet"
        layout="@layout/layout_bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
