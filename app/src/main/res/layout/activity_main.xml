<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f172a">

    <!-- AutoFitTextureView exigido pela biblioteca pedroSG94 para preview -->
    <com.pedro.library.view.AutoFitTextureView
        android:id="@+id/cameraPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Overlay superior: título + status RTSP -->
    <LinearLayout
        android:id="@+id/topOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#CC0f172a"
        android:padding="12dp"
        android:layout_gravity="top"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="rtsp://0.0.0.0:8554/live"
            android:textSize="11sp"
            android:textColor="#94a3b8"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/rtspIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● RTSP :8554"
            android:textSize="12sp"
            android:textColor="#ef4444"
            android:background="#0f172a"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp" />

    </LinearLayout>

    <!-- HUD: canto superior direito -->
    <include
        android:id="@+id/hudLayout"
        layout="@layout/layout_hud"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="60dp"
        android:layout_marginEnd="8dp" />

    <!-- Coluna de FABs lado direito -->
    <LinearLayout
        android:id="@+id/fabContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="12dp"
        android:gravity="center_horizontal"
        android:elevation="6dp">

        <ImageButton
            android:id="@+id/fabSwitchCamera"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_fab"
            android:src="@android:drawable/ic_menu_camera"
            android:tint="#f1f5f9"
            android:contentDescription="Trocar câmara"
            android:scaleType="centerInside"
            android:padding="12dp" />

        <ImageButton
            android:id="@+id/fabFlash"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_fab"
            android:src="@android:drawable/ic_menu_compass"
            android:tint="#f1f5f9"
            android:contentDescription="Flash"
            android:scaleType="centerInside"
            android:padding="12dp" />

        <ImageButton
            android:id="@+id/fabTakePhoto"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_fab"
            android:src="@android:drawable/ic_menu_gallery"
            android:tint="#f1f5f9"
            android:contentDescription="Captar foto"
            android:scaleType="centerInside"
            android:padding="12dp" />

        <ImageButton
            android:id="@+id/fabToggleHud"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_fab"
            android:src="@android:drawable/ic_menu_info_details"
            android:tint="#38bdf8"
            android:contentDescription="Alternar HUD"
            android:scaleType="centerInside"
            android:padding="12dp" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabControls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_manage"
            app:tint="#f1f5f9"
            app:backgroundTint="#1e40af"
            android:contentDescription="Controles" />

    </LinearLayout>

    <!-- Bottom Sheet -->
    <include
        android:id="@+id/bottomSheet"
        layout="@layout/layout_bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
