<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f172a">

    <!-- Preview da câmera (ocupa área central) -->
    <TextureView
        android:id="@+id/cameraPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="80dp"
        android:layout_marginBottom="200dp" />

    <!-- Texto de placeholder quando preview estiver desligado -->
    <TextView
        android:id="@+id/previewOffText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="📹 Preview Desligado\n\nToque em 'Ligar Preview' para ativar"
        android:textSize="18sp"
        android:textColor="#cbd5e1"
        android:textAlignment="center"
        android:visibility="gone" />

    <!-- Barra superior de controles -->
    <LinearLayout
        android:id="@+id/topControlBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1e293b"
        android:padding="12dp"
        android:layout_gravity="top"
        android:elevation="4dp">

        <!-- Título e status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📡 Camera2 RTSP Server"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#38bdf8" />

            <TextView
                android:id="@+id/rtspIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● RTSP"
                android:textSize="12sp"
                android:textColor="#10b981"
                android:background="#0f172a"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp" />

        </LinearLayout>

        <!-- URLs e controles principais -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/statusText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="rtsp://192.168.0.1:8554\nhttp://192.168.0.1:8080"
                android:textSize="11sp"
                android:textColor="#94a3b8"
                android:fontFamily="monospace"
                android:lineSpacingExtra="2dp" />

            <!-- Botão Preview ON/OFF -->
            <Button
                android:id="@+id/btnTogglePreview"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Desligar Preview"
                android:textSize="11sp"
                android:textColor="#f1f5f9"
                android:background="#ef4444"
                android:paddingHorizontal="12dp"
                android:layout_marginStart="8dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Barra lateral esquerda com botões de câmera -->
    <LinearLayout
        android:id="@+id/leftControlBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="12dp"
        android:background="#1e293b"
        android:padding="8dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CÂMERA"
            android:textSize="10sp"
            android:textColor="#64748b"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:gravity="center" />

        <Button
            android:id="@+id/btnCameraWide"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:text="Wide"
            android:textSize="11sp"
            android:background="@drawable/bg_button_primary"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnCameraUltra"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:text="Ultra Wide"
            android:textSize="10sp"
            android:background="@drawable/bg_button_secondary"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnCameraTele"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:text="Telephoto"
            android:textSize="10sp"
            android:background="@drawable/bg_button_secondary"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnCameraFront"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:text="Frontal"
            android:textSize="11sp"
            android:background="@drawable/bg_button_secondary" />

    </LinearLayout>

    <!-- Barra lateral direita com ações -->
    <LinearLayout
        android:id="@+id/rightControlBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="12dp"
        android:background="#1e293b"
        android:padding="8dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AÇÕES"
            android:textSize="10sp"
            android:textColor="#64748b"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:gravity="center" />

        <Button
            android:id="@+id/btnFlash"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:text="Flash"
            android:textSize="11sp"
            android:background="@drawable/bg_button_secondary"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnTakePhoto"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:text="Foto"
            android:textSize="11sp"
            android:background="@drawable/bg_button_secondary"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnToggleHud"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:text="HUD"
            android:textSize="11sp"
            android:background="@drawable/bg_button_secondary"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:text="Config"
            android:textSize="11sp"
            android:background="@drawable/bg_button_secondary" />

    </LinearLayout>

    <!-- HUD de informações em tempo real (canto superior direito) -->
    <include
        android:id="@+id/hudLayout"
        layout="@layout/layout_hud"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="100dp"
        android:layout_marginEnd="110dp" />

    <!-- Painel inferior com controles rápidos -->
    <LinearLayout
        android:id="@+id/bottomControlBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1e293b"
        android:padding="16dp"
        android:layout_gravity="bottom"
        android:elevation="4dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CONTROLES RÁPIDOS"
            android:textSize="11sp"
            android:textColor="#64748b"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- Controle de ISO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="ISO"
                android:textSize="12sp"
                android:textColor="#f1f5f9"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/seekIso"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="20" />

            <TextView
                android:id="@+id/txtIsoValue"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="680"
                android:textSize="12sp"
                android:textColor="#38bdf8"
                android:gravity="end"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- Controle de Exposição -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="EXP"
                android:textSize="12sp"
                android:textColor="#f1f5f9"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/seekExposure"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="50" />

            <TextView
                android:id="@+id/txtExposureValue"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="1/500s"
                android:textSize="11sp"
                android:textColor="#38bdf8"
                android:gravity="end"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- Controle de Foco -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="FOCUS"
                android:textSize="12sp"
                android:textColor="#f1f5f9"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/seekFocus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="0" />

            <TextView
                android:id="@+id/txtFocusValue"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="AUTO"
                android:textSize="11sp"
                android:textColor="#38bdf8"
                android:gravity="end"
                android:fontFamily="monospace" />

        </LinearLayout>

    </LinearLayout>

    <!-- Bottom Sheet (painel de configurações avançadas) -->
    <include
        android:id="@+id/bottomSheet"
        layout="@layout/layout_bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
