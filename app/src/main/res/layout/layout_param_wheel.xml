<?xml version="1.0" encoding="utf-8"?>
<!--
  Roda de ajuste que aparece ao tocar num dial da barra inferior.
  Posiciona-se sobre o dial tocado com uma SeekBar circular (substituída
  por uma SeekBar horizontal compacta por compatibilidade).
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/paramWheelContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#EE0f172a"
    android:paddingHorizontal="20dp"
    android:paddingVertical="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/wheelLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ISO"
            android:textSize="11sp"
            android:textColor="#38bdf8"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/wheelValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="800"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#f8fafc"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/wheelAuto"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="AUTO"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#22c55e"
            android:background="@drawable/bg_badge_green"
            android:paddingHorizontal="8dp"
            android:layout_marginStart="10dp" />

    </LinearLayout>

    <SeekBar
        android:id="@+id/wheelSeek"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="50"
        android:progressTint="#38bdf8"
        android:thumbTint="#38bdf8" />

</LinearLayout>
