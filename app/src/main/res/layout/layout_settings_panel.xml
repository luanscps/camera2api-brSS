<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="match_parent"
    android:background="#F0060d17"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="56dp"
        android:paddingHorizontal="16dp"
        android:paddingBottom="80dp">

        <!-- Cabecalho -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="CONFIGURACOES"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#94a3b8"
                android:letterSpacing="0.15" />

            <ImageButton
                android:id="@+id/btnClosePanel"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="#64748b"
                android:contentDescription="Fechar" />

        </LinearLayout>

        <!-- ======================================================= -->
        <!-- SECCAO: RTMP                                             -->
        <!-- ======================================================= -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DESTINO RTMP"
            android:textSize="9sp"
            android:textColor="#38bdf8"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="IP do PC onde o MediaMTX esta rodando"
            android:textSize="10sp"
            android:textColor="#64748b"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/editRtmpUrl"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="rtmp://192.168.1.100:1935/live/stream"
            android:textSize="11sp"
            android:textColor="#f1f5f9"
            android:textColorHint="#475569"
            android:fontFamily="monospace"
            android:background="@drawable/bg_spinner"
            android:paddingHorizontal="10dp"
            android:inputType="textUri"
            android:imeOptions="actionDone"
            android:singleLine="true"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnApplyRtmpUrl"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Aplicar e Reconectar"
            android:textSize="12sp"
            android:textColor="#000000"
            android:backgroundTint="#38bdf8"
            android:layout_marginBottom="20dp" />

        <!-- Divisor -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#1e293b" android:layout_marginBottom="16dp"/>

        <!-- ======================================================= -->
        <!-- SECCAO: VIDEO                                            -->
        <!-- ======================================================= -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VIDEO"
            android:textSize="9sp"
            android:textColor="#38bdf8"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:layout_marginBottom="10dp" />

        <!-- Resolucao -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Resolucao"
                android:textSize="13sp"
                android:textColor="#cbd5e1" />

            <Spinner
                android:id="@+id/spinResolution"
                android:layout_width="120dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_spinner"
                android:popupBackground="#1e293b" />

        </LinearLayout>

        <!-- Frame rate -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Frame Rate"
                android:textSize="13sp"
                android:textColor="#cbd5e1" />

            <Spinner
                android:id="@+id/spinFrameRate"
                android:layout_width="120dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_spinner"
                android:popupBackground="#1e293b" />

        </LinearLayout>

        <!-- Bitrate -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bitrate"
                android:textSize="13sp"
                android:textColor="#cbd5e1" />

            <Spinner
                android:id="@+id/spinBitrate"
                android:layout_width="120dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_spinner"
                android:popupBackground="#1e293b" />

        </LinearLayout>

        <!-- Divisor -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#1e293b" android:layout_marginBottom="16dp"/>

        <!-- ======================================================= -->
        <!-- SECCAO: CAMERA                                           -->
        <!-- ======================================================= -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CAMERA"
            android:textSize="9sp"
            android:textColor="#38bdf8"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:layout_marginBottom="10dp" />

        <!-- OIS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Estabilizacao OIS"
                android:textSize="13sp"
                android:textColor="#cbd5e1" />

            <Switch
                android:id="@+id/switchOis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:thumbTint="#38bdf8"
                android:trackTint="#1e40af" />

        </LinearLayout>

        <!-- Grade -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Grade 3x3"
                android:textSize="13sp"
                android:textColor="#cbd5e1" />

            <Switch
                android:id="@+id/switchGrid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#38bdf8"
                android:trackTint="#334155" />

        </LinearLayout>

        <!-- HUD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="HUD info"
                android:textSize="13sp"
                android:textColor="#cbd5e1" />

            <Switch
                android:id="@+id/switchHud"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:thumbTint="#38bdf8"
                android:trackTint="#1e40af" />

        </LinearLayout>

        <!-- Divisor -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#1e293b" android:layout_marginBottom="16dp"/>

        <!-- ======================================================= -->
        <!-- SECCAO: AUDIO                                            -->
        <!-- ======================================================= -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AUDIO"
            android:textSize="9sp"
            android:textColor="#38bdf8"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Audio no stream"
                android:textSize="13sp"
                android:textColor="#cbd5e1" />

            <Switch
                android:id="@+id/switchAudio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:thumbTint="#38bdf8"
                android:trackTint="#1e40af" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ganho do microfone"
                android:textSize="13sp"
                android:textColor="#cbd5e1" />

            <SeekBar
                android:id="@+id/seekMicGain"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="70"
                android:progressTint="#38bdf8"
                android:thumbTint="#38bdf8" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
